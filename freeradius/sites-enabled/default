server default {

listen {
    type = auth
    ipaddr = *
    port = 1812
    proto = tcp
}

listen {
    type = acct
    ipaddr = *
    port = 1813
    proto = tcp
}

authorize {
    preprocess
    sql

    # Custom dynamic Pool-Name lookup from Django database
    update control {
        Pool-Name := "%{sql:SELECT CONCAT(c.nome, '_', c.pool_name_input) FROM coringa_cliente c JOIN coringa_clienteip ip ON c.id = ip.cliente_id WHERE (ip.endereco_ip = '%{NAS-IP-Address}' OR ip.endereco_ip LIKE CONCAT('%{NAS-IP-Address}', '/%%')) AND c.habilitar_pool = 1 AND c.status = 'ativo' LIMIT 1}"
    }

    if (!ok) {
        update control {
            Auth-Type := Accept
        }
    }

    if (&control:Auth-Type == "Accept") {
        update reply {
            Framed-Protocol := PPP
            Service-Type := Framed-User
            Mikrotik-Rate-Limit := "50M/50M"
        }
    }

    eap
    pap
}

authenticate {
    Auth-Type Accept {
        update reply {
            Framed-Protocol := PPP
            Service-Type := Framed-User
            Mikrotik-Rate-Limit := "50M/50M"
            
        }
    }

    Auth-Type PAP {
        pap
    }
    Auth-Type CHAP {
        chap
    }
    Auth-Type MS-CHAP {
        mschap
    }
    eap
}

preacct {
    preprocess
    acct_unique
}

accounting {
    sql
    sqlippool
}

session {
}

post-auth {
    sql

    if (control:Pool-Name) {
        sqlippool
    }

    update reply {
        Framed-Protocol := PPP
        Service-Type := Framed-User
        Mikrotik-Rate-Limit := "50M/50M"
    }

    Post-Auth-Type REJECT {
        sql
    }
}

}
